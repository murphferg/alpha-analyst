{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Alpha Analyst: Run main.py (TSLA)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/src/alpha_analyst_rag_hub/.venv/bin/python",
      "program": "${workspaceFolder}/src/alpha_analyst_rag_hub/main.py",
      "cwd": "${workspaceFolder}/src/alpha_analyst_rag_hub",
      "args": [
        "TSLA"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Alpha Analyst: Run + Open Agent Inspector",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5679
      },
      "preLaunchTask": "Open Agent Inspector",
      "postDebugTask": "Terminate All Tasks",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
