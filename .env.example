# =============================================================================
# Alpha Analyst — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env to source control.
# =============================================================================

# ── News API ──────────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
NEWS_API_KEY=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── RAG Hub LLM backend ───────────────────────────────────────────────────────
# "openai" uses the OpenAI API; "stub" returns canned responses (no key needed)
LLM_BACKEND=stub
