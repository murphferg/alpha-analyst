{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://alpha-analyst/schemas/sec_filing.json",
  "title": "SecFiling",
  "description": "A SEC filing fetched from EDGAR by the Ingestion service.",
  "type": "object",
  "required": ["accession_number", "cik", "company_name", "form_type", "filing_date", "fetched_at"],
  "properties": {
    "accession_number": {
      "type": "string",
      "description": "EDGAR accession number (e.g. 0001234567-24-000001).",
      "pattern": "^[0-9]{10}-[0-9]{2}-[0-9]{6}$"
    },
    "cik": {
      "type": "string",
      "description": "SEC Central Index Key (10-digit zero-padded).",
      "pattern": "^[0-9]{1,10}$"
    },
    "company_name": {
      "type": "string",
      "description": "Name of the registrant company."
    },
    "form_type": {
      "type": "string",
      "description": "SEC form type (e.g. 10-K, 10-Q, 8-K)."
    },
    "filing_date": {
      "type": "string",
      "format": "date",
      "description": "Date the filing was submitted to EDGAR."
    },
    "document_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the filing index page on SEC.gov."
    },
    "description": {
      "type": ["string", "null"],
      "description": "Optional highlighted excerpt from the filing text."
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when this record was fetched by the ingestion service."
    }
  },
  "additionalProperties": false
}
